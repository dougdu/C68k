	title	"IEEE 754 single-precision absolute value"
; ============================================================
;  _fabs / _fabsf — absolute value of single-precision float
;
;  float _fabs(float x) — returns |x| in D0
;  Clears the sign bit.
; ============================================================

	.model	flat
	include	ieee754.inc

	public	_fabs, _fabsf

	.code

_fabs:
_fabsf:
	move.l	4(sp),d0
	andi.l	#$7FFFFFFF,d0		; clear sign bit
	rts

	end
